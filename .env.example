# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# ── Redis ──────────────────────────────────────────────────────────────────
# Password for the Redis instance.  Must be the same in the redis, api,
# and worker services.  Choose a strong random string in production.
REDIS_PASSWORD=changeme_use_a_strong_random_string

# ── Frontend ───────────────────────────────────────────────────────────────
# Host port the frontend is exposed on (container always listens on 3000).
FRONTEND_PORT=3000

# ── Deploy (only needed on the production server / in GitHub Secrets) ──────
# Registry prefix used by the rolling-update script.
# Example: ghcr.io/yourorg/yourrepo
REGISTRY=ghcr.io/your-org/your-repo
